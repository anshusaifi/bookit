# Copy this file to .env and fill in your values

PORT=5000

# PostgreSQL connection string
# When running via Docker Compose, host is the service name "postgres"
# When running locally, change host to "localhost"
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bookit

# PostgreSQL credentials — must match DATABASE_URL above
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bookit

# JWT secret — use any long random string in production
JWT_SECRET=change_me_to_a_long_random_secret
